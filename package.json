  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint-plugin-vue": "^9.32.0",
    "typescript-eslint": "^8.0.0"
  }
}
